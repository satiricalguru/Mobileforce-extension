{
  "manifest_version": 3,
  "name": "MobileForce — OTT Mobile Spoofer",
  "version": "1.0.0",
  "description": "Forces websites to think your browser is a mobile device. Bypasses OTT mobile-only restrictions by spoofing User-Agent, touch events, and screen dimensions.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/spoof-main.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/spoof-bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
